# Iris local stack — copy to .env and fill in your own keys, then run ./setup.sh.
# NEVER commit .env (it is gitignored). This template carries placeholders only.

# --- Anthropic -------------------------------------------------------------
# The `claude` CLI (the full agent brain for voice + daemon) uses its OWN login
# (`claude login`), so a key here is only needed for direct-API code paths.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Telegram daemon (iris.py) ---------------------------------------------
# Create a bot with @BotFather; paste the token it gives you.
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_BOT_TOKEN=000000000:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Comma-separated numeric Telegram user IDs allowed to command the bot.
IRIS_TELEGRAM_USER_IDS=000000000

# --- Obsidian (second-brain vault access) ----------------------------------
# From the Obsidian "Local REST API" community plugin settings.
OBSIDIAN_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# --- ElevenLabs (cloud TTS for the video VO pipeline) ----------------------
# The LOCAL two-way voice (voice/voice_chat.py) uses kokoro and needs no key;
# these are only for the billed video-narration render in vo_factory.
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID=xxxxxxxxxxxxxxxxxxxxxxxx
