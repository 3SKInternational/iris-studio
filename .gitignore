.env
.env.*
!.env.example
.venv/
__pycache__/
*.pyc
.DS_Store

# Backup-chain files from the pre-git era — superseded by git history
*.bak
*.bak-*

# Stray captured-output file from 2026-05-25 setup
arrow

# YouTube OAuth credentials (Builds 3+4) — NEVER commit. The downloaded Google
# OAuth client secret + the captured authorized-user token (carries the
# refresh_token). Same rule as .env: creds live on the Mini only, never the repo.
client_secret*.json
youtube_token.json
*_token.json

# Local logs (real logs live at ~/iris_studio/logs/)
logs/

# Symlink into the vault (set up per-machine; not portable)
STEVE_CONTEXT.md

# SQLite databases — live mutating state with conversation history.
# Never commit: bloat + privacy. iris.db moved to /Volumes/AI_Workspace/iris_studio/
# on 2026-05-27 per commit 589eb99.
*.db
*.db-journal
*.db-wal
*.db-shm

# Daily SQLite dumps from scripts/dump-iris-db.sh (A-6) — same privacy
# concern as the live .db; mirror the SQL form of conversation history.
backups/

# Per-machine Claude Code local config — carries a personal permission
# allowlist + machine-specific hooks. Stays local, never versioned.
.claude/settings.local.json

# local image-render spend ledger (data, not code)
image_factory/cost_ledger.jsonl
